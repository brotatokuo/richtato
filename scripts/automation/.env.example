# Statement automation environment variables.
# Append these to the project root .env (loaded by docker-compose).

# --- Richtato API credentials (for posting downloaded statements) -----------
# The automation container POSTs to http://backend:8000 inside the Docker
# network using HTTP Basic auth. RICHTATO_USER must be an active Django user
# (typically the superuser).
RICHTATO_USER=alan
RICHTATO_PASS=replace-me
RICHTATO_BASE_URL=http://backend:8000

# --- Gmail SMTP alerts ------------------------------------------------------
# Requires 2FA on the sending Google account and a generated App Password.
# Leave GMAIL_USER/GMAIL_APP_PASSWORD/ALERT_TO blank to disable email alerts
# (failures will still be logged).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=aaaa bbbb cccc dddd
ALERT_TO=you@gmail.com

# --- Scheduling -------------------------------------------------------------
# Container TZ controls schedule.every().day.at(...) wall-clock interpretation.
TZ=America/Los_Angeles
RUN_TIME=06:00
RUN_TIMEZONE=America/Los_Angeles

# --- Behaviour ---------------------------------------------------------------
# Comma-separated list of institutions to run. Omit to enable all supported.
# Supported: bofa,marcus,amex,robinhood_bank,fidelity,robinhood_investments,guideline,chase
AUTOMATION_INSTITUTIONS=

# JSON map: institution slug -> Richtato account ID. The runner needs this so
# it can tell the import API which account each downloaded file belongs to.
# Example:
#   AUTOMATION_ACCOUNT_IDS={"bofa": 1, "marcus": 2, "chase": 3, "amex": 4, "fidelity": 5, "robinhood_bank": 6, "robinhood_investments": 7, "guideline": 8}
AUTOMATION_ACCOUNT_IDS={}

# Number of days without a successful run before a "stale" alert fires.
STALE_THRESHOLD_DAYS=3

# Headless browser by default. Set to false only for local debugging with a display.
AUTOMATION_HEADLESS=true
BANK_AUTOMATION_DB_MODE=1
BANK_AUTOMATION_DB_POLL_SECONDS=60
RICHTATO_BASE_URL=http://backend:8000
RICHTATO_USER=<your-richtato-username>
RICHTATO_PASS=<your-richtato-password>