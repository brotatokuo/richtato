# Bank Sync (Playwright cookie-only flow)
# Fernet key (base64-urlsafe 32 bytes) used to encrypt the Playwright
# storage_state JSON and per-account activity URLs. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Falls back to a SECRET_KEY-derived key for local dev only.
BANK_SYNC_FERNET_KEY=
# How often the bank-sync agent polls Richtato for due tasks (seconds).
# Manual "Sync now" clicks land on the next poll, so keep this short for UX.
BANK_SYNC_POLL_SECONDS=30
# Where the agent talks to the API. The agent authenticates with a DRF
# token belonging to a Django user that has is_automation_runner=True.
# Generate it by running: docker compose exec backend python manage.py create_automation_runner
RICHTATO_BASE_URL=http://backend:8000
RICHTATO_RUNNER_TOKEN=
# X11 display for headed bank sign-in (interactive_login). Requires the X11
# overlay and a host-side TCP bridge (Docker Desktop cannot mount
# /tmp/.X11-unix without manual file-sharing setup):
#
#   xhost +local:
#   python3 scripts/bank_sync/x11_bridge.py
#   docker compose -f docker-compose.yml -f docker-compose.x11.yml up -d automation
#
# Path to the copied X authority cookie the container reads (generated from
# $XAUTHORITY on the host). Refresh after reboot:
#   cp "$XAUTHORITY" local_data/.xauthority
BANK_SYNC_X11_DISPLAY=host.docker.internal:0
BANK_SYNC_XAUTHORITY=./local_data/.xauthority
