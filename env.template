# How often the automation container polls for due connections (seconds).
# Manual "Sync now" clicks land on the next poll, so keep this short for UX.
BANK_AUTOMATION_DB_POLL_SECONDS=60
# Fernet key (base64-urlsafe 32 bytes). Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
